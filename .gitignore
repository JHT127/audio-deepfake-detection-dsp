# =============================================================
#  Audio Deepfake Detection — .gitignore
# =============================================================

# ----- Raw & processed audio data (large / regenerable) ------
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/split.csv

# ----- External data (large / regenerable) -------------------
data/external/protocol.txt

# ----- Results (regenerable by running the pipeline) ---------
results/features.csv
results/.DS_Store

# Figures are committed so reviewers can see output without re-running.
# To exclude them too, uncomment:
# results/figures/*
# !results/figures/.gitkeep

# ----- Python ------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg

# ----- Jupyter -----------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
notebooks/

# ----- OS junk -----------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*~
*.swp
*.swo

# ----- IDEs --------------------------------------------------
.vscode/
.idea/
*.suo
*.user

# ----- Misc --------------------------------------------------
*.log
*.tmp
*.bak
